<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.template.MainController"
            style="-fx-background-color: #0F172A;">

    <!-- ===== HEADER ===== -->
    <top>
        <VBox spacing="10" style="-fx-background-color: #1E293B; -fx-padding: 20;">
            <Label text="Student Management System"
                   style="-fx-text-fill: #A78BFA; -fx-font-size: 26px; -fx-font-weight: bold;" />

            <!-- Buttons Row -->
            <HBox spacing="10">
                <Button fx:id="addStudentButton" text="Add Student"
                        onAction="#handleAddStudent"
                        style="-fx-background-color: #6366F1; -fx-text-fill: white;" />

                <Button fx:id="editStudentButton" text="Edit Student"
                        onAction="#handleEditStudent"
                        style="-fx-background-color: #8B5CF6; -fx-text-fill: white;" />

                <Button fx:id="deleteStudentButton" text="Delete Student"
                        onAction="#handleDeleteStudent"
                        style="-fx-background-color: #EF4444; -fx-text-fill: white;" />

                <Button fx:id="clearButton" text="Clear"
                        onAction="#handleClearForm"
                        style="-fx-background-color: #475569; -fx-text-fill: white;" />
            </HBox>
        </VBox>
    </top>

    <!-- ===== MAIN CONTENT ===== -->
    <center>
        <HBox spacing="20" style="-fx-padding: 20;">

            <!-- ===== LEFT FORM CARD ===== -->
            <VBox spacing="15"
                  prefWidth="320"
                  style="-fx-background-color: #1E293B; -fx-padding: 20; -fx-background-radius: 12;">

                <Label text="Student Information"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />

                <TextField fx:id="studentIdField" promptText="Student ID"/>
                <TextField fx:id="fullNameField" promptText="Full Name"/>
                <TextField fx:id="programmeField" promptText="Programme"/>
                <TextField fx:id="levelField" promptText="Level"/>
                <TextField fx:id="gpaField" promptText="GPA"/>
                <TextField fx:id="emailField" promptText="Email"/>
                <TextField fx:id="phoneField" promptText="Phone"/>

            </VBox>

            <!-- ===== RIGHT TABLE SECTION ===== -->
            <VBox spacing="15" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #1E293B; -fx-padding: 20; -fx-background-radius: 12;">

                <!-- Filter & Sort -->
                <HBox spacing="10">
                    <ComboBox fx:id="programmeFilter"
                              onAction="#handleProgrammeFilter"
                              promptText="Filter by Programme"
                              prefWidth="180"/>

                    <Button text="Sort by GPA"
                            onAction="#handleSortByGpa"
                            style="-fx-background-color: #6366F1; -fx-text-fill: white;" />

                    <Button text="Sort by Name"
                            onAction="#handleSortByName"
                            style="-fx-background-color: #6366F1; -fx-text-fill: white;" />

                    <Button fx:id="reportsButton"
                            text="Reports"
                            onAction="#openReportsWindow"
                            style="-fx-background-color: #F59E0B; -fx-text-fill: white;" />
                </HBox>

                <!-- Table -->
                <TableView fx:id="studentTable"
                           VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #0F172A;
                                  -fx-control-inner-background: #0F172A;
                                  -fx-text-fill: white;">

                    <columns>
                        <TableColumn fx:id="idColumn" text="Student ID" />
                        <TableColumn fx:id="nameColumn" text="Full Name" />
                        <TableColumn fx:id="programmeColumn" text="Programme" />
                        <TableColumn fx:id="levelColumn" text="Level" />
                        <TableColumn fx:id="gpaColumn" text="GPA" />
                        <TableColumn fx:id="emailColumn" text="Email" />
                        <TableColumn fx:id="phoneColumn" text="Phone" />
                    </columns>
                </TableView>

            </VBox>

        </HBox>
    </center>

</BorderPane>