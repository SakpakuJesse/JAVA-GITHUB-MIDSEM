<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.template.ReportsController"
            style="-fx-background-color: #141414;">

    <!-- ===== HEADER ===== -->
    <top>
        <HBox style="-fx-background-color: #1F1F2E; -fx-padding: 15;">
            <Label text="Student Reports"
                   style="-fx-text-fill: #BB86FC; -fx-font-size: 22px; -fx-font-weight: bold;" />
        </HBox>
    </top>

    <!-- ===== MAIN CONTENT ===== -->
    <center>
        <HBox spacing="25" style="-fx-padding: 20;">

            <!-- ===== LEFT CONTROL PANEL ===== -->
            <VBox spacing="15"
                  prefWidth="280"
                  style="-fx-background-color: #1F1F2E; -fx-padding: 20; -fx-background-radius: 12;">

                <Label text="Report Controls"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />

                <Label text="Minimum GPA"
                       style="-fx-text-fill: #BBBBBB;" />

                <TextField fx:id="gpaThresholdField"
                           promptText="e.g. 3.0"
                           style="-fx-background-color: #2C2C3E; -fx-text-fill: white;" />

                <Button text="Generate Report"
                        onAction="#handleLoadReport"
                        style="-fx-background-color: #BB86FC; -fx-text-fill: black;" />

                <Button text="Clear Report"
                        onAction="#handleClearReport"
                        style="-fx-background-color: #444; -fx-text-fill: white;" />

                <Separator />

                <Label text="Data Options"
                       style="-fx-text-fill: white; -fx-font-weight: bold;" />

                <Button text="Export to CSV"
                        onAction="#handleExportCSV"
                        style="-fx-background-color: #03DAC6; -fx-text-fill: black;" />

                <Button text="Import from CSV"
                        onAction="#handleImportCSV"
                        style="-fx-background-color: #03DAC6; -fx-text-fill: black;" />

            </VBox>

            <!-- ===== RIGHT TABLE AREA ===== -->
            <VBox spacing="15"
                  HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #1F1F2E; -fx-padding: 20; -fx-background-radius: 12;">

                <Label text="Report Results"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />

                <TableView fx:id="reportTable"
                           VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #141414;
                                  -fx-control-inner-background: #141414;
                                  -fx-table-cell-border-color: #2C2C3E;
                                  -fx-text-fill: white;">

                    <columns>
                        <TableColumn fx:id="idColumn" text="ID" />
                        <TableColumn fx:id="nameColumn" text="Name" />
                        <TableColumn fx:id="programmeColumn" text="Programme" />
                        <TableColumn fx:id="levelColumn" text="Level" />
                        <TableColumn fx:id="gpaColumn" text="GPA" />
                        <TableColumn fx:id="emailColumn" text="Email" />
                        <TableColumn fx:id="phoneColumn" text="Phone" />
                    </columns>

                </TableView>

            </VBox>

        </HBox>
    </center>

</BorderPane>